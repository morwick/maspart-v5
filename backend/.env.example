# ── Lingkungan ─────────────────────────────────────────────────────────
# dev  : validasi keamanan hanya jadi peringatan (warning) — untuk lokal.
# prod : validasi keamanan KETAT — server gagal start bila JWT_SECRET masih
#        default/lemah atau PAYMENT_CALLBACK_SECRET kosong. Set ke "prod" saat deploy.
APP_ENV=dev

# ── Supabase (sama dengan .streamlit/secrets.toml [supabase]) ──────────
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGci...
# service_key untuk akses Storage (stok.xlsx/harga.xlsx) bila bucket private.
# Kosongkan kalau bucket publik / mau pakai anon key.
SUPABASE_SERVICE_KEY=eyJhbGci...
SUPABASE_TABLE=users
SUPABASE_DATA_BUCKET=data

# ── JWT ────────────────────────────────────────────────────────────────
# WAJIB diganti dengan string acak panjang di produksi.
# Contoh generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=ganti-dengan-secret-acak-panjang
JWT_EXPIRE_MINUTES=720

# ── Data ───────────────────────────────────────────────────────────────
# Folder berisi file Excel part (default: folder data/ milik project Streamlit).
# Relatif terhadap backend/ atau absolut.
DATA_DIR=../data

# ── CORS (frontend Next.js) ────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Ongkir (RajaOngkir / Komerce) ──────────────────────────────────────
# Ambil key di https://rajaongkir.komerce.id (dashboard → API key).
RAJAONGKIR_API_KEY=
SHIP_ORIGIN_POSTAL=10110
# Opsional: isi ID lokasi RajaOngkir asal kalau tak mau dicari via kode pos.
SHIP_ORIGIN_ID=
SHIP_DEFAULT_ITEM_GRAMS=1000

# ── Pembayaran (Payment API Komerce) ───────────────────────────────────
# Key "Payment API" dari dashboard Komerce (Developer → Settings → API Key).
PAYMENT_API_KEY=
PAYMENT_SANDBOX=true
# Secret untuk verifikasi signature webhook (isi di produksi).
PAYMENT_CALLBACK_SECRET=
# URL publik backend untuk menerima callback (di produksi: domain https).
PUBLIC_BASE_URL=http://127.0.0.1:8001

# ── Asisten AI (DeepSeek — OpenAI-compatible) ──
# Ambil API key di https://platform.deepseek.com (menu API Keys).
DEEPSEEK_API_KEY=
# Model: "deepseek-chat" (cepat, default) atau "deepseek-reasoner" (lebih analitis).
DEEPSEEK_MODEL=deepseek-chat
# Base URL (jarang diubah):
# DEEPSEEK_BASE_URL=https://api.deepseek.com
